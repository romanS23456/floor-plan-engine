```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Test cache
.pytest_cache/
.coverage
coverage/

# Logs
*.log

# Environment files
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# OS files
.DS_Store
Thumbs.db

# Dependencies
venv/
.venv/
.mypy_cache/
```